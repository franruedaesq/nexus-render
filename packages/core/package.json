{
  "name": "@nexus-render/core",
  "version": "0.1.0",
  "description": "High-performance headless 3D rendering library for Node.js (Rust/wgpu via napi-rs)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "scripts": {
    "build": "napi build --platform --release --dts _generated.d.ts",
    "build:debug": "napi build --platform --dts _generated.d.ts",
    "test": "jest",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.7.3"
  },
  "napi": {
    "binaryName": "nexus-render-core",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "optionalDependencies": {
    "@nexus-render/core-linux-x64-gnu": "0.1.0"
  }
}
