{
  "name": "@nexus-render/core",
  "version": "0.1.1",
  "description": "High-performance headless 3D rendering library for Node.js (Rust/wgpu via napi-rs)",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "license": "MIT",
  "author": "Nexus Render Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franruedaesq/nexus-render.git",
    "directory": "packages/core"
  },
  "keywords": [
    "3d",
    "rendering",
    "headless",
    "wgpu",
    "napi",
    "gltf",
    "glb",
    "rust",
    "node",
    "offscreen"
  ],
  "scripts": {
    "build": "napi build --platform --release --dts _generated.d.ts",
    "build:debug": "napi build --platform --dts _generated.d.ts",
    "create-npm-dirs": "napi create-npm-dirs",
    "test": "jest",
    "prepublishOnly": "napi prepublish -t npm",
    "publish:dry": "npm publish --dry-run --access public",
    "publish:npm": "npm publish --access public",
    "release": "npm run build && npm run test && npm run publish:npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.7.3"
  },
  "napi": {
    "binaryName": "nexus-render-core",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "optionalDependencies": {
    "@nexus-render/core-linux-x64-gnu": "0.1.1"
  }
}